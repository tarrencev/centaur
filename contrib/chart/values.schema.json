{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "global": {
      "type": "object",
      "properties": {
        "imagePullSecrets": { "type": "array" }
      }
    },
    "firewall": {
      "type": "object",
      "properties": {
        "existingCaSecretName": { "type": "string" },
        "existingCaKeySecretName": { "type": "string" },
        "ca": {
          "type": "object",
          "properties": {
            "certPem": { "type": "string" },
            "keyPem": { "type": "string" }
          }
        }
      }
    },
    "ironProxy": {
      "type": "object",
      "properties": {
        "service": {
          "type": "object",
          "properties": {
            "proxyPort": { "type": "integer" },
            "managementPort": { "type": "integer" },
            "healthPort": { "type": "integer" },
            "pgPortRangeStart": { "type": "integer" },
            "pgPortRangeEnd": { "type": "integer" }
          }
        },
        "secretSource": { "type": "string" },
        "secretTtl": { "type": "string" }
      }
    },
    "toolServer": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "type": "integer" }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "bootstrapSecretName": { "type": "string" }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "egressDiscovery": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string" },
            "clusterDomain": { "type": "string" },
            "tailnetFqdnAnnotation": { "type": "string" }
          }
        },
        "slackEtlEnabled": { "type": "boolean" },
        "slackSyncIntervalSeconds": { "type": "integer" },
        "slackSyncLookbackDays": { "type": "integer" },
        "slackSyncThreadLookbackDays": { "type": "integer" },
        "companyContextDocumentsIntervalSeconds": { "type": "integer" }
      }
    },
    "overlay": {
      "type": "object",
      "properties": {
        "mountPath": { "type": "string" },
        "systemPrompt": { "type": "string" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string" },
            "sourcePath": { "type": "string" }
          }
        }
      }
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "runtimeClassName": { "type": "string" },
        "serviceAccountName": { "type": "string" },
        "automountServiceAccountToken": { "type": "boolean" },
        "reposPath": { "type": "string" },
        "resources": { "type": "object" }
      }
    },
    "repoCache": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": {
          "type": "string",
          "enum": ["hostPath", "mirror"]
        },
        "hostPath": { "type": "string" },
        "service": {
          "type": "object",
          "properties": {
            "port": { "type": "integer" }
          }
        },
        "persistence": {
          "type": "object",
          "properties": {
            "existingClaim": { "type": "string" },
            "size": { "type": "string" },
            "storageClassName": { "type": "string" },
            "accessModes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "repositories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "syncIntervalSeconds": { "type": "integer" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string" }
          }
        },
        "githubToken": {
          "type": "object",
          "properties": {
            "existingSecretName": { "type": "string" },
            "secretKey": { "type": "string" },
            "token": { "type": "string" }
          }
        },
        "egressPorts": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "resources": { "type": "object" }
      }
    },
    "agentSandbox": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "namespace": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" },
            "name": { "type": "string" }
          }
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string" }
          }
        },
        "controller": {
          "type": "object",
          "properties": {
            "extensions": { "type": "boolean" }
          }
        }
      }
    },
    "slackbot": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "persistence": {
          "type": "object",
          "properties": {
            "subPath": { "type": "string" }
          }
        }
      }
    },
    "runnerAccess": {
      "type": "object",
      "properties": {
        "allowedCidrs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressSourceNamespaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "apiIngressSourceNamespaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ingressControllerNamespaces": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
